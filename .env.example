PORT=3001
OUTPUT_DIR=./out

# GitHub App (for webhook server)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# GitHub PAT (for CLI testing only)
GITHUB_TOKEN=

# LLM provider: "openai" (default), "anthropic", or "vertex"
LLM_PROVIDER=openai

# OpenAI — used for TTS always, and for analysis when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-mini

# Anthropic — used for analysis when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Anthropic on Vertex AI — used for analysis when LLM_PROVIDER=vertex
# Uses Google Cloud ADC — run `gcloud auth application-default login` or set GOOGLE_APPLICATION_CREDENTIALS
# Also reads ANTHROPIC_VERTEX_PROJECT_ID and CLOUD_ML_REGION if set
VERTEX_PROJECT=
VERTEX_LOCATION=us-east5
VERTEX_MODEL=claude-sonnet-4-20250514

# Fast model for file review batches (defaults to main model)
# Used in "fast" and "standard" analysis depth. "deep" always uses the main model.
# Use a faster/cheaper model here for speed (e.g., claude-haiku-4-5@20251001)
LLM_FAST_MODEL=

# TTS
TTS_VOICE=onyx
TTS_SPEED=1.1

# Google Cloud Storage
# Uses ADC — run `gcloud auth application-default login` locally,
# or WIF handles auth in CI automatically.
GCS_BUCKET=

# Render
RENDER_CONCURRENCY=4
RENDER_CHUNKS=6
SCENE_MAP_ENABLED=true
